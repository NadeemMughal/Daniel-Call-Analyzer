    {
      "id": "a1b2c3d4-0001-0001-0001-000000000009",
      "name": "Build Participants",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 250],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const callRow = ($('Insert Call').first().json || [])[0];\nconst callId = callRow ? callRow.id : null;\nif (!callId) return [];\n\nconst attendees = $('Verify HMAC').first().json.body.attendees || [];\nif (attendees.length === 0) return [];\n\nconst members = $input.all()[0]?.json || [];\nconst emailMap = {};\nfor (const m of members) {\n  if (m.email) emailMap[m.email.toLowerCase().trim()] = m;\n}\n\nconst participants = attendees.map((a, i) => {\n  const email = (a.email || '').toLowerCase().trim();\n  const member = emailMap[email];\n  const isInternal = !!member;\n  return {\n    call_id: callId,\n    name: a.name || a.email || 'Unknown',\n    email: a.email || '',\n    role: (i === 0 || isInternal) ? 'host' : 'guest',\n    is_external: !isInternal,\n    team_member_id: member ? member.id : null\n  };\n});\n\nif (participants.length === 0) return [];\nreturn [{ json: { participants } }];"
      }
    },
