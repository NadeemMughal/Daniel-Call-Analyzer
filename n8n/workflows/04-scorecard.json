    {
      "id": "a1b2c3d4-0004-0004-0004-000000000007",
      "name": "Build Evidence Array",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1960, 180],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const scorecardRow = ($('Insert Scorecard').first().json || [])[0];\nconst scorecardId = scorecardRow ? scorecardRow.id : null;\nconst allEvidence = $('Parse Scorecard').first().json.all_evidence || [];\nif (!scorecardId || allEvidence.length === 0) return [{ json: { __skip_evidence: true } }];\nconst evidenceRows = allEvidence.map(e => ({ scorecard_id: scorecardId, criterion_key: e.criterion_key, quote: e.quote, timestamp_seconds: e.timestamp_seconds }));\nreturn [{ json: { evidence: evidenceRows } }];"
      }
