        "sendBody": true,
        "contentType": "json",
        "body": { "mode": "raw", "rawBody": "={ \"call_id\": \"{{ $('Webhook').first().json.call_id }}\" }" },
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0004-0004-0004-000000000012",
      "name": "Respond 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
