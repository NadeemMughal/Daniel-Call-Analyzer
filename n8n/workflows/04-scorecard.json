    {
      "id": "a1b2c3d4-0004-0004-0004-check-transcript",
      "name": "Check Transcript",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawCall = $('Get Call').first().json;\nconst call = Array.isArray(rawCall) ? (rawCall[0] || {}) : (rawCall || {});\nconst callId = $('Webhook').first().json.body.call_id;\nconst transcript = (call.transcript_raw || '').trim();\nconst hasTranscript = transcript.length >= 50;\nreturn [{ json: { call_id: callId, has_transcript: hasTranscript } }];"
      }
    },
