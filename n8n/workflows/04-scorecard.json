    {
      "id": "a1b2c3d4-0004-0004-0004-build-score-01",
      "name": "Build Score Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 180],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rawCall = $('Get Call').first().json;\nconst call = Array.isArray(rawCall) ? (rawCall[0] || {}) : (rawCall || {});\nconst rawRubric = $('Get Active Rubric').first().json;\nconst rubric = Array.isArray(rawRubric) ? (rawRubric[0] || {}) : (rawRubric || {});\nconst transcript = (call.transcript_raw || 'No transcript available.').substring(0, 6000);\nconst rubricContent = JSON.stringify(rubric.content || {}, null, 2).substring(0, 1500);\n\nconst systemPrompt = [\n  'You are an expert sales coach reviewing a recorded sales call for WeBuildTrades, a UK marketing agency for trade businesses.',\n  '',\n  'Evaluate the rep performance against the sales playbook below and return a structured coaching scorecard.',\n  '',\n  'Sales Playbook (active rubric):',\n  rubricContent,\n  '',\n  'Scoring instructions:',\n  '- Score each criterion from 0 to 10 (0 = very poor, 10 = excellent)',\n  '- overall_score = weighted average across all scoring_criteria using their weight values',\n  '- For each strength and improvement, include an exact quoted phrase from the transcript as evidence',\n  '- Be specific and actionable — tell the rep exactly what to do differently',\n  '- If this is a team call (internal meeting), score leniently on sales criteria and note it',\n  '',\n  'Return ONLY valid JSON, no markdown, no explanation outside the JSON. Schema:',\n  '{\"overall_score\": 7.5, \"summary\": \"2-3 sentence coaching summary\", \"strengths\": [{\"criterion\": \"key\", \"score\": 8, \"description\": \"what rep did well\", \"evidence_quote\": \"exact quote\", \"timestamp_seconds\": 120}], \"improvements\": [{\"criterion\": \"key\", \"score\": 4, \"description\": \"what to improve and how\", \"evidence_quote\": \"quote showing issue\", \"timestamp_seconds\": 45}]}'\n].join('\\n');\n\nreturn [{\n  json: {\n    model: 'claude-sonnet-4-6',\n    max_tokens: 1500,\n    system: systemPrompt,\n    messages: [\n      { role: 'user', content: 'Please evaluate this sales call transcript:\\n\\n' + transcript }\n    ]\n  }\n}];"
      }
    },
    {
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Score with Groq",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1300, 180],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0004-0004-0004-000000000005",
      "name": "Parse Scorecard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 180],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const responseText = $input.first().json.content?.[0]?.text || '';\nconst callId = $('Webhook').first().json.body.call_id;\nconst rawRubricPS = $('Get Active Rubric').first().json;\nconst rubric = Array.isArray(rawRubricPS) ? (rawRubricPS[0] || null) : (rawRubricPS || null);\n\n// Strip markdown code fences the LLM sometimes wraps around JSON\nlet cleanText = responseText.trim();\ncleanText = cleanText.replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```\\s*$/i, '').trim();\n\nlet scorecard;\ntry {\n  scorecard = JSON.parse(cleanText);\n} catch (e) {\n  throw new Error('Failed to parse LLM scorecard: ' + responseText.substring(0, 300));\n}\n\nif (typeof scorecard.overall_score !== 'number') scorecard.overall_score = 0;\nif (!Array.isArray(scorecard.strengths)) scorecard.strengths = [];\nif (!Array.isArray(scorecard.improvements)) scorecard.improvements = [];\nif (!scorecard.summary) scorecard.summary = '';\n\nconst allEvidence = [\n  ...scorecard.strengths.filter(s => s.evidence_quote).map(s => ({ criterion_key: s.criterion, quote: s.evidence_quote, timestamp_seconds: s.timestamp_seconds || null })),\n  ...scorecard.improvements.filter(s => s.evidence_quote).map(s => ({ criterion_key: s.criterion, quote: s.evidence_quote, timestamp_seconds: s.timestamp_seconds || null }))\n];\n\nreturn [{ json: {\n  call_id: callId,\n  rubric_id: rubric ? rubric.id : null,\n  overall_score: Math.round(scorecard.overall_score * 10) / 10,\n  summary: scorecard.summary,\n  strengths: scorecard.strengths,\n  improvements: scorecard.improvements,\n  llm_model: 'claude-sonnet-4-6',\n  all_evidence: allEvidence\n} }];"
      }
    },
