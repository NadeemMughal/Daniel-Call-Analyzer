        "specifyBody": "json",
        "jsonBody": "={{ { call_id: $json.call_id, rubric_id: $json.rubric_id, overall_score: $json.overall_score, summary: $json.summary, strengths: $json.strengths, improvements: $json.improvements, llm_model: $json.llm_model } }}",
        "options": {}
