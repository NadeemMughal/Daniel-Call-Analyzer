        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      }
    },
    {
      "id": "c90dd3c8-5e5a-444b-a6c5-ba18ecbabee7",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-64, 1040],
      "parameters": {
        "jsCode": "const responseText = $input.first().json.content?.[0]?.text || '';\nconst callId = $('Webhook').first().json.body.call_id;\nconst validTypes = ['discovery', 'ads_intro', 'launch', 'follow_up', 'team', 'other'];\n\nlet cleanText = responseText.trim().replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```\\s*$/i, '').trim();\n\nlet classification;\ntry {\n  classification = JSON.parse(cleanText);\n} catch (e) {\n  classification = { call_type: 'other', confidence: 0, reasoning: 'parse error: ' + responseText.substring(0, 100) };\n}\n\nif (!validTypes.includes(classification.call_type)) {\n  classification.call_type = 'other';\n}\n\nreturn [{ json: { ...classification, call_id: callId } }];"
      }
    },
    {
      "id": "2596800f-d2b1-405f-ac59-dae9aa539da1",
      "name": "Match Client",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [160, 1040],
      "parameters": {
        "jsCode": "const callId = $('Parse Classification').item.json.call_id;\nreturn [{ json: { call_id: callId, client_id: null } }];"
      }
    },
