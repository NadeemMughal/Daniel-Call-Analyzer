    {
      "id": "b9f2d8a1-4c3e-4a5f-8e7b-1d2c3f4e5a6b",
      "name": "Build Groq Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-512, 1040],
      "parameters": {
        "jsCode": "const call = ($input.all()[0]?.json || [])[0] || {};\nconst transcript = (call.transcript_raw || '').substring(0, 2000);\n\nreturn [{\n  json: {\n    model: 'claude-haiku-4-5-20251001',\n    max_tokens: 300,\n    system: 'You are a call classifier for a sales coaching system.\\nReturn ONLY valid JSON, no other text.\\n\\ncall_type must be one of: discovery, ads_intro, launch, follow_up, team, other\\n\\nResponse schema: {\"call_type\": \"discovery\", \"confidence\": 0.95, \"reasoning\": \"brief explanation\"}',\n    messages: [\n      {\n        role: 'user',\n        content: 'Classify this sales call transcript:\\n\\n' + (transcript || 'No transcript available')\n      }\n    ]\n  }\n}];"
      }
    },
    {
      "id": "28787ce8-1ee3-4e8a-880e-79e395748a87",
      "name": "Classify with Groq",
