        "jsCode": "const responseText = $input.first().json.choices?.[0]?.message?.content || '';\nconst callId = $('Insert Call').first().json[0].id;\nconst validTypes = ['discovery', 'ads_intro', 'launch', 'follow_up', 'team', 'other'];\nlet classification;\ntry { classification = JSON.parse(responseText); } catch (e) { classification = { call_type: 'other', confidence: 0, reasoning: 'parse error' }; }\nif (!validTypes.includes(classification.call_type)) classification.call_type = 'other';\nreturn [{ json: { ...classification, call_id: callId } }];"
