        "jsCode": "const participants = $('Get Participants').all();\nconst scorecardRes = $('Get Final Scorecard').first().json;\nconst scorecard = Array.isArray(scorecardRes) ? scorecardRes[0] : scorecardRes;\nconst callId = $('Parse Classification').first().json.call_id;\nconst portalUrl = 'http://localhost:5173/calls/' + callId;\nconst safeScorecard = scorecard || { overall_score: null, summary: 'No scorecard generated.', strengths: [], improvements: [] };\nconst strengths = (safeScorecard.strengths || []).slice(0, 3);\nconst improvements = (safeScorecard.improvements || []).slice(0, 3);\nconst emailTargets = participants\n  .filter(p => p.json.team_members && p.json.team_members.email)\n  .map(p => ({ to: p.json.team_members.email, name: p.json.team_members.name || 'Team Member', overall_score: safeScorecard.overall_score, summary: safeScorecard.summary || '', strengths, improvements, portal_url: portalUrl }));\nif (emailTargets.length === 0) {\n  emailTargets.push({\n    to: 'muhammadammaralibhutta@gmail.com',\n    name: 'Admin (demo fallback)',\n    overall_score: safeScorecard.overall_score,\n    summary: safeScorecard.summary || '',\n    strengths,\n    improvements,\n    portal_url: portalUrl\n  });\n}\nreturn emailTargets.map(t => ({ json: t }));"
